<%= turbo_frame_tag(dom_id(@watching)) do %>
  <div class="card">
    <div class="card-body">
      <%= form_for @watching.film, url: user_film_path, method: :put do |f| %>
        <div class="row g-2 mb-3">
          <div class="col-md-6"> <%= f.text_field :name_rus, class: "form-control", placeholder: "Название" %> </div>
          <div class="col-md-6"> <%= f.text_field :name_eng, class: "form-control", placeholder: "Title" %> </div>
          <div class="col-md-6"> <%= f.text_field :tomatoes, class: "form-control", placeholder: "Tomatoes" %> </div>
          <div class="col-md-6"> <%= f.text_field :imdb, class: "form-control", placeholder: "IMDB" %> </div>
          <div class="col-md-2">
            <%= f.check_box :seria, class: "form-check-input me-1" %>
            <%= f.label :seria, "Seria", class: "form-check-label" %>
          </div>
          <div class="col-auto d-flex align-items-center">
            <%= hidden_field_tag :professional, "0" %>
            <%= check_box_tag :professional, "1", @watching.professional, class: "form-check-input me-1" %>
            <%= label_tag :professional, "Professional" %>
          </div>
        </div>

        <div class="row g-2 mb-3 align-items-center">
          <div class="col-auto">
            <%= text_field_tag :rate, @watching.rate, class: "form-control", placeholder: "My rate" %>
          </div>
          <div class="col-auto">
            <%= date_field_tag :start, @watching.start, class: "form-control" %>
          </div>
          <div class="col-auto">
            <%= button_tag "<->", id: "swap", type: "button", class: "btn btn-outline-secondary" %>
          </div>
          <div class="col-auto">
            <%= date_field_tag :finish, @watching.finish, class: "form-control" %>
          </div>
        </div>

        <%= f.submit class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
<% end %>


<% if false %>
<%= turbo_frame_tag(dom_id(watch_object)) do %>
  <div class="card mb-1">
    <div class="card-body">
      <div class="row align-items-center gx-2" title="<%= watch_object.hint %>">
        <div class="col-6 text-truncate <%= watch_object.html_classes %>">
          <%= watch_object.film.name %>
        </div>
        <div class="col-6">
          <div class="row align-items-center gx-2">
            <div class="col-4 text-center <%= 'watched' if watch_object.finish %>">
              <%= watch_object.dates %>
            </div>
            <div class="col-3 text-center">
              <%= critics(watch_object.film) %>
            </div>
            <div class="col-3 text-center">
              <%= user_rate(watch_object.rate) %>
            </div>
            <div class="col-2 text-end">
              <% if policy(@user).update? %>
                <%= link_to "X", user_film_path(id: watch_object.id),
                      data: { method: :delete, confirm: "You sure?" } %> |
                <%= link_to 'Edit', edit_user_film_path(id: watch_object.id) %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
<% end %>
