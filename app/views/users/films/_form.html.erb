<%= form_for film, url: user_films_path do |f| %>
  <%= hidden_field_tag :film_type, type %>
  <%= f.text_field :name_rus, placeholder: 'Название' %>

  <% if type == :consumed %>
    <%= f.text_field :name_eng, placeholder: 'Title' %>
    <%= f.text_field :tomatoes, placeholder: 'Tomatoes' %>
    <%= f.text_field :imdb, placeholder: 'IMDB' %>
  <% end %>

  <%= f.check_box :seria %> Seria

  <% if type == :consumed %>
    <%= check_box_tag :professional %> Professional
    <%= text_field_tag :rate, '', placeholder: 'My rate' %>
    <span data-controller="swap">
      <%= date_field_tag :start, nil, 'data-swap-target': 'left' %>
      <%= button_tag '<->', type: 'button', 'data-action': 'click->swap#execute' %>
      <%= date_field_tag :finish, Time.zone.today, 'data-swap-target': 'right' %>
    </span>
  <% end %>

  <%= f.submit %>
<% end %>
