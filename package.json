{
  "name": "devoured",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "@rails/ujs": "^7.1.3-4",
    "bootstrap": "^5.3.3",
    "jquery": "^4.0.0"
  },
  "version": "0.1.0",
  "engines": {
    "node": "^20.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "sass": "^1.77.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/application.js --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "yarn build:sass && yarn copy:fonts",
    "build:sass": "sass ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "copy:fonts": "cp -r node_modules/@fortawesome/fontawesome-free/webfonts public/webfonts"
  }
}
